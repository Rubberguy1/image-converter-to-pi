# Normalize line endings in the repo to LF. Critical for shell scripts, which
# must be LF to run on the Raspberry Pi (CRLF => "bad interpreter" errors).
* text=auto eol=lf
*.sh text eol=lf
*.service text eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.bmp binary
*.ico binary
