# Copy to .env and edit. All values are optional; sensible defaults apply.

# --- Matrix ---
# auto (hardware if available else emulator) | hardware | emulator
MATRIX_BACKEND=auto
MATRIX_WIDTH=64
MATRIX_HEIGHT=64

# Hardware tuning (Pi only). adafruit-hat, or adafruit-hat-pwm after the solder mod.
MATRIX_HARDWARE_MAPPING=adafruit-hat
# Raise if the image flickers or shows side-lines (try 2, 3, 4).
MATRIX_GPIO_SLOWDOWN=2
MATRIX_BRIGHTNESS=70
# Many 64x64 panels need this. If output is garbled/red/half-lit, set FM6126A.
MATRIX_PANEL_TYPE=
# Usually 0. Some panels need a multiplexing (1-17) or row-address type (1-4).
MATRIX_MULTIPLEXING=0
MATRIX_ROW_ADDRESS_TYPE=0

# --- Music sync ---
MUSIC_ENABLED=false
# none | plex | vlc | lastfm
MUSIC_PROVIDER=none
MUSIC_POLL_SECONDS=4

# Plex
PLEX_BASE_URL=
PLEX_TOKEN=

# VLC (enable the Web interface in VLC and set a password)
VLC_BASE_URL=http://localhost:8080
VLC_PASSWORD=

# Last.fm (universal — works with YouTube Music, VLC, etc. via scrobbling)
LASTFM_API_KEY=
LASTFM_USER=

# --- WLED power sync ---
WLED_ENABLED=false
WLED_BASE_URL=            # e.g. http://192.168.1.60
# panel_follows_wled | wled_follows_panel | mirror
WLED_SYNC_DIRECTION=panel_follows_wled
WLED_POLL_SECONDS=3
