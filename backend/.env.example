# Copy to .env and edit. All values are optional; sensible defaults apply.

# --- Matrix ---
# auto (hardware if available else emulator) | hardware | emulator
MATRIX_BACKEND=auto

# Panel layout. A "panel" is one module (usually 64x64). Total resolution =
# (panel_cols * panels_wide) x (panel_rows * panels_tall). Most of these are also
# editable from the web UI's Settings menu.
MATRIX_PANEL_COLS=64
MATRIX_PANEL_ROWS=64
MATRIX_PANELS_WIDE=1
MATRIX_PANELS_TALL=1
MATRIX_ORIENTATION=0        # 0 / 90 / 180 / 270

# Hardware tuning (Pi only). adafruit-hat, or adafruit-hat-pwm after the solder mod.
MATRIX_HARDWARE_MAPPING=adafruit-hat
# Pixel clock speed. Pi 3: 1-2, Pi 4: 3-4. (Not usually the flicker fix — see below.)
MATRIX_GPIO_SLOWDOWN=2
MATRIX_BRIGHTNESS=70
# Colour depth per channel (1-11; 11 is the Pi library max = full colour).
MATRIX_PWM_BITS=11
# THE anti-flicker knob. Lower = higher refresh. Too low = ghosting / imperfect
# blacks. 130 default; try 100 if you see flicker, back off if you see trails.
MATRIX_PWM_LSB_NANOSECONDS=130
# Cap the refresh rate (0 = unlimited). Pin (e.g. 120) only if refresh varies.
MATRIX_LIMIT_REFRESH_RATE_HZ=0
# Many 64x64 panels need this. If output is garbled/red/half-lit, set FM6126A.
MATRIX_PANEL_TYPE=
# Usually 0. Some panels need a multiplexing (1-17) or row-address type (1-4).
MATRIX_MULTIPLEXING=0
MATRIX_ROW_ADDRESS_TYPE=0

# --- Music sync ---
MUSIC_ENABLED=false
# none | plex | vlc | lastfm
MUSIC_PROVIDER=none
MUSIC_POLL_SECONDS=4

# Plex
PLEX_BASE_URL=
PLEX_TOKEN=

# VLC (enable the Web interface in VLC and set a password)
VLC_BASE_URL=http://localhost:8080
VLC_PASSWORD=

# Last.fm (universal — works with YouTube Music, VLC, etc. via scrobbling)
LASTFM_API_KEY=
LASTFM_USER=

# --- Custom scene / weather widget (Open-Meteo, free, no key) ---
# Also editable from the web UI's Scene editor.
WEATHER_LAT=0.0
WEATHER_LON=0.0
WEATHER_UNIT=fahrenheit     # fahrenheit | celsius

# --- WLED power sync ---
WLED_ENABLED=false
WLED_BASE_URL=            # e.g. http://192.168.1.60
# panel_follows_wled | wled_follows_panel | mirror
WLED_SYNC_DIRECTION=panel_follows_wled
WLED_POLL_SECONDS=3
